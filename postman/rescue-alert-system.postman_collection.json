    {
      "name": "Messages",
      "description": "Send and retrieve messages. Supports text and voice attachments. All endpoints require a Firebase Bearer token.\n\nThe `sender` field is set automatically from the authenticated Firebase user.",
      "item": [
        {
          "name": "List Messages",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/message/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", ""]
            },
            "description": "Returns all messages."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"sender\": {\n      \"id\": 1,\n      \"username\": \"<firebase_uid>\",\n      \"email\": \"jdoe@example.com\",\n      \"role\": \"rescuer\"\n    },\n    \"title\": \"Evacuation Update\",\n    \"text\": \"Sector 3 is clear.\",\n    \"voice_url\": null,\n    \"latitude\": 40.7128,\n    \"longitude\": -74.0060,\n    \"timestamp\": \"2024-01-15T10:35:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "List Messages (Newest First)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/message/list_messages/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", "list_messages", ""]
            },
            "description": "Returns all messages ordered by timestamp descending (newest first)."
          }
        },
        {
          "name": "Create Message (Text)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Evacuation Update\",\n  \"text\": \"Sector 3 is clear. All units proceed to sector 4.\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/message/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", ""]
            },
            "description": "Create a text message. `sender` is set automatically from the authenticated user. `latitude`, `longitude`, and `text` are optional."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"sender\": {\n    \"id\": 1,\n    \"username\": \"<firebase_uid>\",\n    \"email\": \"jdoe@example.com\",\n    \"role\": \"rescuer\"\n  },\n  \"title\": \"Evacuation Update\",\n  \"text\": \"Sector 3 is clear. All units proceed to sector 4.\",\n  \"voice_url\": null,\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"timestamp\": \"2024-01-15T10:35:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Create Message (With Voice)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Voice Update", "type": "text" },
                { "key": "text", "value": "See attached audio", "type": "text", "description": "Optional" },
                { "key": "latitude", "value": "40.7128", "type": "text", "description": "Optional" },
                { "key": "longitude", "value": "-74.0060", "type": "text", "description": "Optional" },
                { "key": "voice_file", "type": "file", "src": "", "description": "Audio file attachment" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/message/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", ""]
            },
            "description": "Create a message with a voice file attachment. Use `multipart/form-data` (do not set Content-Type manually — Postman sets it automatically with the boundary). The response includes a `voice_url` pointing to the uploaded file."
          }
        },
        {
          "name": "Get Message",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/message/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", "1", ""]
            },
            "description": "Retrieve a single message by ID."
          }
        },
        {
          "name": "Update Message (Full)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
