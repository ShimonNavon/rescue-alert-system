            "body": {
              "mode": "raw",
              "raw": "{\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/user/location/",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "location", ""]
            },
            "description": "Update the authenticated user's current GPS coordinates."
          }
        },
        {
          "name": "Get All Users with Coordinates",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/user/all/",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "all", ""]
            },
            "description": "Returns all user profiles that have a non-null latitude and longitude. Useful for rendering users on a map."
          }
        },
        {
          "name": "Update User Profile by ID (Full)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"rescuer\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/user/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "1", ""]
            },
            "description": "Replace all fields on a specific user profile by ID (admin use)."
          }
        },
        {
          "name": "Update User Profile by ID (Partial)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
