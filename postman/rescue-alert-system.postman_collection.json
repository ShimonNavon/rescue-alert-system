{
  "info": {
    "name": "Rescue Alert System",
    "description": "Complete API reference for the Rescue Alert System backend.\n\n**Authentication:** All endpoints require a Firebase ID Token sent as a Bearer token:\n```\nAuthorization: Bearer <firebase_id_token>\n```\nObtain an ID token from the Firebase SDK (`user.getIdToken()`) or via the Firebase REST API. Set the `firebase_token` collection variable before sending any request.\n\nSet `base_url` to your server (e.g. `http://localhost:8000`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000",
      "description": "Base URL of the backend server"
    },
    {
      "key": "firebase_token",
      "value": "",
      "description": "Firebase ID Token — obtain via user.getIdToken() in the Firebase SDK or the Firebase REST Auth API"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{firebase_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Alerts",
      "description": "Create and manage rescue alerts. All endpoints require a Firebase Bearer token.",
      "item": [
        {
          "name": "List Alerts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/alerts/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", ""]
            },
            "description": "Returns all alerts ordered by newest first."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"title\": \"Fire on Main St\",\n    \"description\": \"Building fire, multiple floors\",\n    \"latitude\": 40.7128,\n    \"longitude\": -74.0060,\n    \"status\": \"OPEN\",\n    \"priority\": \"CRITICAL\",\n    \"created_at\": \"2024-01-15T10:30:00Z\",\n    \"updated_at\": \"2024-01-15T10:30:00Z\"\n  }\n]"
            }
          ]
        },
        {
          "name": "Create Alert",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"status\": \"OPEN\",\n  \"priority\": \"CRITICAL\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/alerts/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", ""]
            },
            "description": "Create a new alert.\n\n**status options:** `OPEN`, `DISPATCHED`, `ACCEPTED`, `IN_PROGRESS`, `RESOLVED`, `CANCELLED`\n\n**priority options:** `LOW`, `MEDIUM`, `HIGH`, `CRITICAL`"
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"status\": \"OPEN\",\n  \"priority\": \"CRITICAL\",\n  \"created_at\": \"2024-01-15T10:30:00Z\",\n  \"updated_at\": \"2024-01-15T10:30:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Get Alert",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/alerts/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "1", ""]
            },
            "description": "Retrieve a single alert by ID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"status\": \"OPEN\",\n  \"priority\": \"CRITICAL\",\n  \"created_at\": \"2024-01-15T10:30:00Z\",\n  \"updated_at\": \"2024-01-15T10:30:00Z\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"detail\": \"Not found.\"\n}"
            }
          ]
        },
        {
          "name": "Update Alert (Full)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"status\": \"DISPATCHED\",\n  \"priority\": \"CRITICAL\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/alerts/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "1", ""]
            },
            "description": "Replace all fields on an alert."
          }
        },
        {
          "name": "Update Alert (Partial)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"RESOLVED\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/alerts/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "1", ""]
            },
            "description": "Update one or more fields on an alert without replacing the whole object."
          }
        },
        {
          "name": "Delete Alert",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/alerts/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "1", ""]
            },
            "description": "Permanently delete an alert."
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        },
        {
          "name": "Get Nearby Alerts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/alerts/nearby/?lat=40.7128&lon=-74.0060&radius=5000",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "nearby", ""],
              "query": [
                { "key": "lat", "value": "40.7128", "description": "Latitude of center point" },
                { "key": "lon", "value": "-74.0060", "description": "Longitude of center point" },
                { "key": "radius", "value": "5000", "description": "Search radius in meters" }
              ]
            },
            "description": "Returns all alerts within `radius` meters of the given coordinates (`lat`, `lon`). All three query params are required."
          }
        }
      ]
    },
    {
      "name": "User Profiles",
      "description": "Manage user profiles and locations. All endpoints require a Firebase Bearer token.\n\nNote: Django user accounts are created automatically on first login via Firebase — there is no separate registration endpoint.",
      "item": [
        {
          "name": "List All User Profiles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/user/",
