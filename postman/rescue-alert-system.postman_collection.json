            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/message/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", ""]
            },
            "description": "Returns all messages."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"sender\": {\n      \"id\": 1,\n      \"username\": \"jdoe\",\n      \"email\": \"jdoe@example.com\",\n      \"role\": \"rescuer\"\n    },\n    \"title\": \"Evacuation Update\",\n    \"text\": \"Sector 3 is clear.\",\n    \"voice_url\": null,\n    \"latitude\": 40.7128,\n    \"longitude\": -74.0060,\n    \"timestamp\": \"2024-01-15T10:35:00Z\"\n  }\n]"
            }
          ]
        },
