    },
    {
      "key": "group_id",
      "value": "1",
      "description": "Group ID used in detail, update, and delete requests"
    },
    {
      "key": "message_id",
      "value": "1",
      "description": "Message ID used in detail, update, and delete requests"
    },
    {
      "key": "notification_id",
      "value": "1",
      "description": "Notification token record ID"
    }
  ],
  "auth": {
    "type": "bearer",
    "bearer": [
      {
        "key": "token",
        "value": "{{firebase_token}}",
        "type": "string"
      }
    ]
  },
  "item": [
    {
      "name": "Firebase Auth",
      "description": "Obtain a Firebase ID token. Run Sign In first to populate `firebase_token` ΓÇö all other folders inherit it automatically.\n\nTokens expire after 1 hour. Re-run Sign In to get a fresh one.\n\nIf your Firebase project has Email/Password auth disabled, obtain the token from the mobile app via `user.getIdToken()` and paste it into the `firebase_token` variable manually.",
      "item": [
        {
          "name": "Sign In (Email + Password)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.idToken) {",
                  "    pm.collectionVariables.set('firebase_token', r.idToken);",
                  "    console.log('firebase_token saved. Expires in: ' + r.expiresIn + 's');",
                  "} else {",
                  "    console.error('Sign in failed:', JSON.stringify(r));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\",\n  \"returnSecureToken\": true\n}"
            },
            "url": {
              "raw": "https://identitytoolkit.googleapis.com/v1/accounts:signInWithPassword?key={{firebase_api_key}}",
              "protocol": "https",
              "host": ["identitytoolkit", "googleapis", "com"],
              "path": ["v1", "accounts:signInWithPassword"],
              "query": [
                {
                  "key": "key",
                  "value": "{{firebase_api_key}}",
                  "description": "Firebase Web API key"
                }
              ]
            },
            "description": "Signs in a Firebase user with email and password. On success the test script automatically saves `idToken` to the `firebase_token` collection variable so all subsequent requests are authenticated.\n\nRequires Email/Password sign-in enabled in Firebase console ΓåÆ Authentication ΓåÆ Sign-in providers."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"kind\": \"identitytoolkit#VerifyPasswordResponse\",\n  \"localId\": \"<firebase_uid>\",\n  \"email\": \"user@example.com\",\n  \"displayName\": \"\",\n  \"idToken\": \"<firebase_id_token>\",\n  \"registered\": true,\n  \"refreshToken\": \"<refresh_token>\",\n  \"expiresIn\": \"3600\"\n}"
            },
            {
              "name": "400 Invalid credentials",
              "status": "Bad Request",
              "code": 400,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"error\": {\n    \"code\": 400,\n    \"message\": \"INVALID_LOGIN_CREDENTIALS\",\n    \"errors\": [{ \"message\": \"INVALID_LOGIN_CREDENTIALS\", \"domain\": \"global\", \"reason\": \"invalid\" }]\n  }\n}"
            }
          ]
        },
        {
          "name": "Refresh Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const r = pm.response.json();",
                  "if (r.id_token) {",
                  "    pm.collectionVariables.set('firebase_token', r.id_token);",
                  "    console.log('firebase_token refreshed.');",
                  "} else {",
                  "    console.error('Refresh failed:', JSON.stringify(r));",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/x-www-form-urlencoded" }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                { "key": "grant_type", "value": "refresh_token" },
                { "key": "refresh_token", "value": "<paste_refresh_token_from_sign_in_response>" }
              ]
            },
            "url": {
              "raw": "https://securetoken.googleapis.com/v1/token?key={{firebase_api_key}}",
              "protocol": "https",
              "host": ["securetoken", "googleapis", "com"],
              "path": ["v1", "token"],
              "query": [
                { "key": "key", "value": "{{firebase_api_key}}" }
              ]
            },
            "description": "Use the `refresh_token` from a previous Sign In response to get a new `id_token` without re-entering credentials. The test script auto-saves the new token to `firebase_token`.\n\nUseful for long-running test sessions where the 1-hour token has expired."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"access_token\": \"<new_id_token>\",\n  \"expires_in\": \"3600\",\n  \"token_type\": \"Bearer\",\n  \"refresh_token\": \"<new_refresh_token>\",\n  \"id_token\": \"<new_id_token>\",\n  \"user_id\": \"<firebase_uid>\",\n  \"project_id\": \"<firebase_project_id>\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Alerts",
      "description": "Create and manage rescue alerts. All requests inherit the collection Bearer token.\n\n**Status values:** `OPEN` ΓåÆ `DISPATCHED` ΓåÆ `ACCEPTED` ΓåÆ `IN_PROGRESS` ΓåÆ `RESOLVED` / `CANCELLED`\n\n**Priority values:** `LOW`, `MEDIUM`, `HIGH`, `CRITICAL`\n\n**Coordinates:** `latitude` must be ΓêÆ90 to 90, `longitude` must be ΓêÆ180 to 180. Both must be provided together on updates.",
      "item": [
        {
          "name": "List Alerts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/alerts/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", ""]
            },
            "description": "Returns all alerts ordered by newest first (`-created_at`)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "[\n  {\n    \"id\": 1,\n    \"title\": \"Fire on Main St\",\n    \"description\": \"Building fire, multiple floors\",\n    \"latitude\": 40.7128,\n    \"longitude\": -74.006,\n    \"status\": \"OPEN\",\n    \"priority\": \"CRITICAL\",\n    \"created_at\": \"2024-01-15T10:30:00Z\",\n    \"updated_at\": \"2024-01-15T10:30:00Z\"\n  }\n]"
            },
            {
              "name": "401 Unauthorized ΓÇö missing or expired token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"detail\": \"Authentication credentials were not provided.\"\n}"
            }
          ]
        },
        {
          "name": "Create Alert",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006,\n  \"status\": \"OPEN\",\n  \"priority\": \"CRITICAL\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/alerts/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", ""]
            },
            "description": "Create a new alert. `status` defaults to `OPEN`, `priority` defaults to `MEDIUM` if omitted."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006,\n  \"status\": \"OPEN\",\n  \"priority\": \"CRITICAL\",\n  \"created_at\": \"2024-01-15T10:30:00Z\",\n  \"updated_at\": \"2024-01-15T10:30:00Z\"\n}"
            },
            {
              "name": "400 Bad Request ΓÇö validation error",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"latitude\": [\"Latitude must be between -90 and 90.\"],\n  \"longitude\": [\"Longitude must be between -180 and 180.\"]\n}"
            }
          ]
        },
        {
          "name": "Get Alert",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/alerts/{{alert_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "{{alert_id}}", ""]
            },
            "description": "Retrieve a single alert by ID."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006,\n  \"status\": \"OPEN\",\n  \"priority\": \"CRITICAL\",\n  \"created_at\": \"2024-01-15T10:30:00Z\",\n  \"updated_at\": \"2024-01-15T10:30:00Z\"\n}"
            },
            {
              "name": "404 Not Found",
              "status": "Not Found",
              "code": 404,
              "body": "{\n  \"detail\": \"Not found.\"\n}"
            }
          ]
        },
        {
          "name": "Update Alert (Full)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Fire on Main St\",\n  \"description\": \"Building fire, multiple floors affected\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006,\n  \"status\": \"DISPATCHED\",\n  \"priority\": \"CRITICAL\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/alerts/{{alert_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "{{alert_id}}", ""]
            },
            "description": "Replace all fields on an alert. All fields including `latitude` and `longitude` are required."
          }
        },
        {
          "name": "Update Alert (Partial)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"IN_PROGRESS\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/alerts/{{alert_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "{{alert_id}}", ""]
            },
            "description": "Update one or more fields. If updating coordinates, `latitude` and `longitude` must both be present ΓÇö providing only one returns a 400."
          },
          "response": [
            {
              "name": "400 ΓÇö partial coordinate update rejected",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"non_fields_error\": [\"Both latitude and longitude must be provided together.\"]\n}"
            }
          ]
        },
        {
          "name": "Delete Alert",
          "request": {
            "method": "DELETE",
            "url": {
              "raw": "{{base_url}}/api/alerts/{{alert_id}}/",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "{{alert_id}}", ""]
            },
            "description": "Permanently delete an alert."
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            }
          ]
        },
        {
          "name": "Get Nearby Alerts",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/alerts/nearby/?lat=40.7128&lon=-74.006&radius=5000",
              "host": ["{{base_url}}"],
              "path": ["api", "alerts", "nearby", ""],
              "query": [
                { "key": "lat", "value": "40.7128", "description": "Latitude of center point (float, required)" },
                { "key": "lon", "value": "-74.006", "description": "Longitude of center point (float, required)" },
                { "key": "radius", "value": "5000", "description": "Search radius in meters (integer, required)" }
              ]
            },
            "description": "Returns all alerts within `radius` meters of the given coordinates. All three query params are required. Uses Euclidean approximation (`lat_diff * 111000` and `lon_diff * 111000 * cos(lat)`)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"title\": \"Fire on Main St\",\n    \"description\": \"Building fire\",\n    \"latitude\": 40.7128,\n    \"longitude\": -74.006,\n    \"status\": \"OPEN\",\n    \"priority\": \"CRITICAL\",\n    \"created_at\": \"2024-01-15T10:30:00Z\",\n    \"updated_at\": \"2024-01-15T10:30:00Z\"\n  }\n]"
            },
            {
              "name": "400 ΓÇö missing params",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"lat, lon, and radius query parameters are required\"\n}"
            },
            {
              "name": "400 ΓÇö invalid param types",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"lat and lon must be floats, radius must be an integer\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "User Profiles",
      "description": "Manage user profiles and locations. Django accounts are created automatically on first Firebase-authenticated request ΓÇö there is no separate registration endpoint.\n\n**Role values:** `user` (default), `rescuer`, `admin`\n\nProfile fields exposed: `id`, `username` (Firebase UID), `email`, `role`, `latitude`, `longitude`.",
      "item": [
        {
          "name": "List All User Profiles",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/user/",
              "host": ["{{base_url}}"],
              "path": ["api", "user", ""]
            },
            "description": "Returns all user profiles."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "[\n  {\n    \"id\": 1,\n    \"username\": \"<firebase_uid>\",\n    \"email\": \"jdoe@example.com\",\n    \"role\": \"rescuer\",\n    \"latitude\": 40.7128,\n    \"longitude\": -74.006\n  }\n]"
            }
          ]
        },
        {
          "name": "Get My Profile",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/api/user/profile/",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "profile", ""]
            },
            "description": "Returns the profile of the currently authenticated user (derived from the Bearer token)."
          },
          "response": [
            {
              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"username\": \"<firebase_uid>\",\n  \"email\": \"jdoe@example.com\",\n  \"role\": \"user\",\n  \"latitude\": null,\n  \"longitude\": null\n}"
            }
          ]
        },
        {
          "name": "Update My Profile",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"role\": \"rescuer\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/user/update_profile/",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "update_profile", ""]
