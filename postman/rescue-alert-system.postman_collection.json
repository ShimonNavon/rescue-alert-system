              "name": "200 OK",
              "status": "OK",
              "code": 200,
              "body": "{\n  \"id\": 1,\n  \"username\": \"<firebase_uid>\",\n  \"email\": \"jdoe@example.com\",\n  \"role\": \"rescuer\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.006\n}"
