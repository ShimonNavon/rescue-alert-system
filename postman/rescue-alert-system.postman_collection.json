    {
      "name": "Device Registration (Firebase)",
      "description": "Register a mobile device for push notifications via Firebase. Uses Firebase ID Token auth instead of JWT.",
      "item": [
        {
          "name": "Register Device",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "<firebase_id_token>",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fcm_token\": \"<firebase_cloud_messaging_token>\",\n  \"device_id\": \"unique-device-identifier\",\n  \"platform\": \"android\",\n  \"device_model\": \"Samsung Galaxy S21\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/token",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "token"]
            },
            "description": "Register or update a mobile device for push notifications.\n\n**Auth:** `Authorization: Bearer <firebase_id_token>` — this endpoint uses a Firebase ID Token, NOT a JWT token.\n\n**platform options:** `android`, `ios`, `other`\n\n**device_model:** Optional. Human-readable device name.\n\nIf the device_id already exists for this Firebase user, the FCM token is updated."
          },
          "response": [
            {
              "name": "204 No Content",
              "status": "No Content",
              "code": 204,
              "body": ""
            },
            {
              "name": "400 Bad Request",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"error\": \"Missing required field: fcm_token\"\n}"
            },
            {
              "name": "401 Unauthorized",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"detail\": \"Authentication credentials were not provided.\"\n}"
            }
          ]
        }
      ]
    }
