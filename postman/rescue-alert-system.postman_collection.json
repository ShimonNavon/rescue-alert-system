          }
        },
        {
          "name": "Create Message (Text)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Evacuation Update\",\n  \"text\": \"Sector 3 is clear. All units proceed to sector 4.\",\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/message/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", ""]
            },
            "description": "Create a text message. The `sender` is set automatically from the authenticated user."
          },
          "response": [
            {
              "name": "201 Created",
              "status": "Created",
              "code": 201,
              "body": "{\n  \"id\": 1,\n  \"sender\": {\n    \"id\": 1,\n    \"username\": \"jdoe\",\n    \"email\": \"jdoe@example.com\",\n    \"role\": \"rescuer\"\n  },\n  \"title\": \"Evacuation Update\",\n  \"text\": \"Sector 3 is clear. All units proceed to sector 4.\",\n  \"voice_url\": null,\n  \"latitude\": 40.7128,\n  \"longitude\": -74.0060,\n  \"timestamp\": \"2024-01-15T10:35:00Z\"\n}"
            }
          ]
        },
        {
          "name": "Create Message (With Voice)",
          "request": {
            "method": "POST",
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "title", "value": "Voice Update", "type": "text" },
                { "key": "text", "value": "See attached audio", "type": "text", "description": "Optional" },
                { "key": "latitude", "value": "40.7128", "type": "text" },
                { "key": "longitude", "value": "-74.0060", "type": "text" },
                { "key": "voice_file", "type": "file", "src": "", "description": "Audio file attachment" }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/message/",
              "host": ["{{base_url}}"],
              "path": ["api", "message", ""]
            },
            "description": "Create a message with a voice file attachment. Use `multipart/form-data`. The response includes a `voice_url` pointing to the uploaded file."
          }
        },
