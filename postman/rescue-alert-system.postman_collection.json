              "mode": "raw",
              "raw": "{\n  \"role\": \"admin\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/user/1/",
              "host": ["{{base_url}}"],
              "path": ["api", "user", "1", ""]
            },
            "description": "Partially update a specific user profile by ID (admin use)."
          }
        },
        {
          "name": "Delete User Profile",
          "request": {
            "method": "DELETE",
