    {
      "name": "Device Registration",
      "description": "Register a mobile device for Firebase Cloud Messaging (FCM) push notifications. Requires a Firebase Bearer token.",
      "item": [
        {
          "name": "Register Device",
          "request": {
            "method": "POST",
