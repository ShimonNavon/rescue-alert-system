    {
      "name": "Device Registration",
      "description": "Register a mobile device for Firebase Cloud Messaging (FCM) push notifications.\n\nThis is the **preferred** endpoint for new integrations. It supports multiple devices per user, platform tagging, and upserts on re-registration (same `firebase_uid` + `device_id` pair updates the `fcm_token`).\n\nAuthentication is handled by reading the Bearer token directly ΓÇö not via DRF's `IsAuthenticated`, so a Firebase token must still be provided.",
      "item": [
        {
          "name": "Register / Update Device",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"fcm_token\": \"<firebase_cloud_messaging_token>\",\n  \"device_id\": \"unique-device-identifier\",\n  \"platform\": \"android\",\n  \"device_model\": \"Samsung Galaxy S24\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/notifications/token",
              "host": ["{{base_url}}"],
              "path": ["api", "notifications", "token"]
            },
            "description": "Register or update a device for push notifications.\n\n**Required fields:** `fcm_token`, `device_id`, `platform`\n\n**platform options:** `android`, `ios`, `other`\n\n**device_model:** Optional. Human-readable device name.\n\nIf the same `device_id` is already registered for this Firebase user the `fcm_token` is updated (upsert). Returns 204 on success."
          },
          "response": [
            {
              "name": "204 No Content ΓÇö registered or updated",
              "status": "No Content",
              "code": 204,
              "body": ""
            },
            {
              "name": "400 Bad Request ΓÇö missing required fields",
              "status": "Bad Request",
              "code": 400,
              "body": "{\n  \"fcm_token\": [\"This field is required.\"],\n  \"device_id\": [\"This field is required.\"],\n  \"platform\": [\"This field is required.\"]\n}"
            },
            {
              "name": "401 Unauthorized ΓÇö invalid or missing token",
              "status": "Unauthorized",
              "code": 401,
              "body": "{\n  \"error\": \"Unauthorized\"\n}"
            }
          ]
        }
      ]
    },
    {
      "name": "Notifications (Legacy)",
      "description": "Simple push notification token store. One token per record, not per device.\n\n**Prefer Device Registration** for new integrations ΓÇö it supports multi-device per user and FCM upsert.\n\n`user` is set automatically from the authenticated token and is read-only.",
